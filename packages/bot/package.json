{
  "name": "@0xsyncroot/opentrade-bot",
  "version": "0.0.1",
  "description": "Telegram bot for opentrade (single-owner whitelist).",
  "type": "module",
  "main": "./dist/main.js",
  "module": "./dist/main.js",
  "types": "./dist/start.d.ts",
  "exports": {
    ".": {
      "types": "./dist/start.d.ts",
      "import": "./dist/main.js"
    },
    "./start": {
      "types": "./dist/start.d.ts",
      "import": "./dist/start.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "opentrade-bot": "./dist/main.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/main.ts",
    "start": "node ./dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@grammyjs/conversations": "^2.0.1",
    "@0xsyncroot/opentrade-core": "workspace:*",
    "consola": "^3.3.3",
    "grammy": "^1.32.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5"
  }
}
