{
  "name": "@hiepht/opentrade-core",
  "version": "0.0.1",
  "private": true,
  "description": "Internal core for @hiepht/opentrade — not published, bundled into the CLI artifact at build time.",
  "type": "module",
  "engines": {
    "node": ">=20.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./gmgn": {
      "types": "./dist/gmgn/index.d.ts",
      "import": "./dist/gmgn/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./safety": {
      "types": "./dist/safety/index.d.ts",
      "import": "./dist/safety/index.js"
    },
    "./classifier": {
      "types": "./dist/classifier/index.d.ts",
      "import": "./dist/classifier/index.js"
    },
    "./views": {
      "types": "./dist/views/index.d.ts",
      "import": "./dist/views/index.js"
    },
    "./actions": {
      "types": "./dist/actions/index.d.ts",
      "import": "./dist/actions/index.js"
    },
    "./chains": {
      "types": "./dist/chains/index.d.ts",
      "import": "./dist/chains/index.js"
    },
    "./presets": {
      "types": "./dist/presets/index.d.ts",
      "import": "./dist/presets/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "undici": "^7.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5"
  }
}
